{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "allowJs": true,
    "checkJs": false,

    "paths": {
      "@/*": ["./src/*"]
    },

    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "outDir": "dist",
    "noEmit": true
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist", "storybook-static"]
}
